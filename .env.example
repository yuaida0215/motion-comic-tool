# =====================================================================
# モーションコミック自動生成ツール — 環境変数サンプル
# 使い方: このファイルを .env.local にコピーして値を埋める（.env.local は非公開）
# 各キーが「どのゲートで必要か」をコメントに記載。今は空でも雛形は起動します。
# =====================================================================

# --- G1 コンテ生成（Claude API / vision） ---
ANTHROPIC_API_KEY=sk-ant-...

# --- G2 文字消し・背景inpaint / G3 TTS（いずれも fal.ai 経由） ---
# fal.ai: inpaint と ElevenLabs TTS の両方をこのキーで叩く想定
FAL_KEY=

# --- ストレージ（プロジェクトJSON・生成画像/音声/mp4の保存先）= Supabase 採用 ---
# Supabase プロジェクト設定 → API からコピー（この2つのみ・サーバー側だけで使用）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...            # service_role key（サーバー専用・絶対に公開しない）

# --- 共有パスワード認証（画面・APIともにこれが無いと全ページ /login にリダイレクト） ---
APP_PASSWORD=                                     # ログイン画面で入力する共有パスワード
AUTH_SECRET=                                      # Cookie署名用のランダム文字列（長い乱数。他人に推測されないもの）
# AUTH_TOKEN_VERSION=1                            # 上げると発行済みCookieを全部即時失効できる（緊急時用・任意）

# --- G4 動画書き出し（本番＝Vercel等サーバレスのみ必要）: AWS Remotion Lambda ---
# ローカル開発ではこれらを空のままにしておけば、従来どおりローカルでChromiumを直接起動してレンダーする。
# 本番はサーバレス環境でChromiumを直接起動できないため、AWS Lambda上のレンダーワーカーに投げる。
# 用意の仕方: `npx remotion lambda functions deploy` と `npx remotion lambda sites create` を
# 実行して出た値をここに入れる（README/チャットで手順案内）。
# 変数名を AWS_ACCESS_KEY_ID ではなく REMOTION_AWS_* にしているのは、Vercelが予約している
# AWS_* 環境変数と衝突させないための、Remotion公式の推奨。
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_LAMBDA_REGION=ap-northeast-1
REMOTION_LAMBDA_FUNCTION_NAME=
REMOTION_LAMBDA_SERVE_URL=

# --- 本番URL（省略時はリクエストのoriginを自動使用。通常は設定不要） ---
# RENDER_BASE_URL=https://your-app.vercel.app
